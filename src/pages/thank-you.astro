---
import Base from '../layouts/Base.astro';
---

<Base title="Thank You" description="Thanks for subscribing to BX Health Marketing.">
  <div class="thank-you container">
    <div class="content">
      <span class="checkmark">&#10003;</span>
      <h1>You're in.</h1>
      <p>
        Thanks for subscribing. You'll get our next update in your inbox.
      </p>
      <a href="/" class="back-link">&larr; Back to latest posts</a>
    </div>
  </div>
</Base>

<style>
  .thank-you {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding-block: var(--space-16);
  }

  .content {
    text-align: center;
    max-width: 28rem;
  }

  .checkmark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    font-size: var(--text-3xl);
    color: var(--color-white);
    background-color: var(--color-poppy);
    border-radius: 50%;
    margin-bottom: var(--space-6);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  p {
    font-size: var(--text-lg);
    color: var(--color-ink-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .back-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-poppy);
  }

  .back-link:hover {
    color: var(--color-poppy-dark);
  }
</style>
