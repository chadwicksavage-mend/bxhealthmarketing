---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <span class="logo-mark">BX</span>
      <span class="logo-text">Health Marketing</span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>Latest</a>
      <a href="/blog" class:list={['nav-link', { active: currentPath.startsWith('/blog') }]}>Archive</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-ink);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-white);
  }

  .logo:hover {
    color: var(--color-white);
  }

  .logo-mark {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--color-poppy);
  }

  .logo-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-white);
  }

  .nav {
    display: flex;
    gap: var(--space-6);
  }

  .nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding-block: var(--space-2);
    transition: color var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-link:hover {
    color: var(--color-white);
  }

  .nav-link.active {
    color: var(--color-poppy);
  }

  @media (min-width: 768px) {
    .header-inner {
      height: 5rem;
    }

    .logo-mark {
      font-size: var(--text-3xl);
    }

    .logo-text {
      font-size: var(--text-base);
    }
  }
</style>
