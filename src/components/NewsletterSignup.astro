---
interface Props {
  variant?: 'inline' | 'footer';
}

const { variant = 'inline' } = Astro.props;
---

<aside class:list={['newsletter', `newsletter--${variant}`]}>
  <div class="newsletter-content">
    <h3 class="newsletter-heading">Stay in the loop</h3>
    <p class="newsletter-description">
      Weekly insights at the intersection of marketing and behavioral health. No spam, unsubscribe anytime.
    </p>
  </div>
  <form
    name="newsletter"
    method="POST"
    action="/thank-you"
    data-netlify="true"
    netlify-honeypot="bot-field"
    class="newsletter-form"
  >
    <input type="hidden" name="form-name" value="newsletter" />
    <p class="hidden">
      <label>
        Don't fill this out if you're human: <input name="bot-field" />
      </label>
    </p>
    <div class="form-row">
      <label for="email" class="sr-only">Email address</label>
      <input
        type="email"
        name="email"
        id="email"
        placeholder="you@example.com"
        required
        class="newsletter-input"
      />
      <button type="submit" class="newsletter-button">Subscribe</button>
    </div>
  </form>
</aside>

<style>
  .newsletter {
    padding: var(--space-8);
    background-color: var(--color-paper-warm);
    border-radius: 4px;
  }

  .newsletter--inline {
    margin-top: var(--space-12);
  }

  .newsletter--footer {
    background-color: transparent;
    padding: 0;
    max-width: 24rem;
  }

  .newsletter-heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }

  .newsletter--footer .newsletter-heading {
    color: var(--color-white);
    font-size: var(--text-lg);
  }

  .newsletter-description {
    font-size: var(--text-sm);
    color: var(--color-ink-light);
    margin-bottom: var(--space-4);
  }

  .newsletter--footer .newsletter-description {
    color: rgba(255, 255, 255, 0.6);
  }

  .newsletter-form {
    margin: 0;
  }

  .form-row {
    display: flex;
    gap: var(--space-2);
  }

  .newsletter-input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: var(--color-white);
    color: var(--color-ink);
  }

  .newsletter-input::placeholder {
    color: var(--color-ink-muted);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-poppy);
    box-shadow: 0 0 0 2px rgba(229, 91, 60, 0.1);
  }

  .newsletter--footer .newsletter-input {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-white);
  }

  .newsletter--footer .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .newsletter--footer .newsletter-input:focus {
    border-color: var(--color-poppy);
    background-color: rgba(255, 255, 255, 0.15);
  }

  .newsletter-button {
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
    background-color: var(--color-poppy);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    white-space: nowrap;
  }

  .newsletter-button:hover {
    background-color: var(--color-poppy-dark);
  }

  .hidden {
    display: none;
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
    }

    .newsletter-button {
      width: 100%;
    }
  }
</style>
